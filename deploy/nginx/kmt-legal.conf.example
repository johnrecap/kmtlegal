upstream kmt_legal_next {
  server 127.0.0.1:3000;
  keepalive 32;
}

server {
  listen 80;
  server_name kmt.example.com;

  # Redirect to HTTPS after TLS is configured.
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name kmt.example.com;

  # Configure these paths for the real certificate provider on the VPS.
  ssl_certificate /etc/letsencrypt/live/kmt.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/kmt.example.com/privkey.pem;

  # Allows multipart overhead. The app still enforces MAX_UPLOAD_MB=5 per file.
  client_max_body_size 6m;

  # Enable only after HTTPS renewal and first deploy are verified.
  # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

  # Uploads must never be served by Nginx. The app streams authorized downloads.
  location ^~ /uploads/ {
    return 404;
  }

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_pass http://kmt_legal_next;
  }
}
