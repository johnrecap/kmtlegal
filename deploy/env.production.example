NODE_ENV=production
APP_ENV=production
APP_RELEASE=CHANGE_ME_RELEASE_ID
APP_ORIGIN=https://kmt.example.com
DATABASE_URL=postgresql://CHANGE_ME
DB_SETUP_MODE=existing
PRISMA_POOL_MAX=10
AUTH_SECRET=CHANGE_ME_32_PLUS_CHARS
SESSION_COOKIE_SECURE=true
CSRF_STRICT_ORIGIN=true
KMT_DEMO_PASSWORD=
KMT_DEMO_TOTP_SECRET=
STAFF_2FA_MODE=disabled
INSTALLER_ENABLED=false
INSTALLER_SETUP_TOKEN=
INSTALLER_LOCK_PATH=/var/lib/kmt-legal/install.lock
HOSTING_MODE=terminal-vps
APP_PORT=3000
PANEL_REVERSE_PROXY_READY=false
CPANEL_NODE_APP_READY=false
CPANEL_COMMAND_RUNNER_READY=false

STORAGE_DRIVER=vps-filesystem
UPLOADS_DIR=/var/lib/kmt-legal/uploads
MAX_UPLOAD_MB=5
ALLOWED_UPLOAD_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.2

PAYMENT_PROVIDER=paytabs
PAYMENT_ATTEMPT_EXPIRY_MINUTES=15
PAYMENT_REQUIRE_WEBHOOK_SIGNATURE=true
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_PROVIDER_WEBHOOK_SECRET
PAYTABS_WEBHOOK_SECRET=CHANGE_ME_PROVIDER_WEBHOOK_SECRET
PAYMENT_HOSTED_CHECKOUT_URL_TEMPLATE=CHANGE_ME_HOSTED_CHECKOUT_URL_TEMPLATE

ANALYTICS_ENABLED=true
ENABLE_STITCH_CLONE=false
