{
  "name": "kmt-legal-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "start:local": "node scripts/start-local-server.mjs",
    "lint": "next lint",
    "qa:local": "node scripts/plan23-local-qa.mjs",
    "qa:local:e2e": "node scripts/plan23-local-qa.mjs --include-e2e",
    "qa:local:release": "node scripts/plan23-local-qa.mjs --include-e2e --include-security-audit --local-release-candidate",
    "qa:db": "node scripts/plan23-local-qa.mjs --include-db",
    "qa:release": "node scripts/plan23-local-qa.mjs --include-e2e --include-db --include-security-audit --include-secret-scan --release-gate",
    "security:audit": "npm audit --audit-level=high --omit=dev",
    "security:audit:all": "npm audit --audit-level=moderate",
    "security:secrets": "node scripts/security-secret-scan.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright-with-server.mjs",
    "test:e2e:smoke": "node scripts/run-playwright-with-server.mjs tests/e2e/mvp-smoke.spec.ts",
    "test:e2e:db": "node scripts/run-playwright-with-server.mjs tests/e2e/db-backed.spec.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "stitch:assets": "node scripts/localize-stitch-assets.mjs",
    "stitch:generate": "node scripts/generate-stitch-clone.mjs",
    "stitch:screenshots": "node scripts/capture-stitch-screenshots.mjs",
    "stitch:compare": "python scripts/compare-stitch-screenshots.py",
    "product:screenshots": "node scripts/capture-product-system-screenshots.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans-arabic": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "material-symbols": "^0.45.2",
    "next": "^14.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
