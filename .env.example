NODE_ENV=development
APP_ENV=local
APP_RELEASE=local
APP_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://kmt_legal:kmt_legal_dev_password@localhost:5432/kmt_legal
DB_SETUP_MODE=existing
PRISMA_POOL_MAX=1
AUTH_SECRET=replace-with-local-dev-secret
CLIENT_ACCOUNT_SETUP_SIGNING_SECRET=
SESSION_COOKIE_SECURE=false
CSRF_STRICT_ORIGIN=false
KMT_DEMO_PASSWORD=
KMT_DEMO_TOTP_SECRET=
STAFF_2FA_MODE=disabled
INSTALLER_ENABLED=false
INSTALLER_SETUP_TOKEN=
INSTALLER_LOCK_PATH=/var/lib/kmt-legal/install.lock
HOSTING_MODE=terminal-vps
APP_PORT=3000
PANEL_REVERSE_PROXY_READY=false
CPANEL_NODE_APP_READY=false
CPANEL_COMMAND_RUNNER_READY=false

STORAGE_DRIVER=vps-filesystem
UPLOADS_DIR=/var/lib/kmt-legal/uploads
MAX_UPLOAD_MB=5
ALLOWED_UPLOAD_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png
MALWARE_SCAN_MODE=disabled
CLAMAV_SOCKET_PATH=/run/clamav/clamd.ctl
CLAMAV_TIMEOUT_MS=10000

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.2

PAYMENT_PROVIDER=paymob
PAYTABS_ENABLED=false
PAYMENT_ATTEMPT_EXPIRY_MINUTES=15
PAYMENT_REQUIRE_WEBHOOK_SIGNATURE=false
PAYMENT_RECEIPT_SIGNING_SECRET=
PAYMENT_RECEIPT_TOKEN_MAX_AGE_SECONDS=604800
PAYMENT_STATUS_SIGNING_SECRET=
PAYMENT_STATUS_TOKEN_MAX_AGE_SECONDS=4500
PAYMENT_WEBHOOK_SECRET=
PAYMENT_MAINTENANCE_INTERVAL_SECONDS=300
PAYMENT_MAINTENANCE_BATCH_SIZE=100
PAYMENT_MAINTENANCE_MAX_BATCHES=10
PAYMENT_MAINTENANCE_ALERT_WEBHOOK_URL=
PAYTABS_WEBHOOK_SECRET=
PAYTABS_HOSTED_CHECKOUT_URL_TEMPLATE=
PAYMENT_HOSTED_CHECKOUT_URL_TEMPLATE=
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_PAYMENT_METHOD_IDS=
PAYMOB_REQUEST_TIMEOUT_MS=10000
PAYMOB_API_BASE_URL=https://accept.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://accept.paymob.com/unifiedcheckout/

ANALYTICS_ENABLED=true
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
ENABLE_STITCH_CLONE=true
